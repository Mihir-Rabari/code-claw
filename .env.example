NODE_ENV=development
API_PORT=3001
WEB_PORT=5173

# GitHub integration
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_API_BASE_URL=
GITHUB_USER_AGENT=

# LLM (OpenAI-compatible; defaults to Gemini)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_MODEL=gemini-2.0-flash

# CodeClaw local memory location
CODECLAW_MEMORY_DIR=.codeclaw
